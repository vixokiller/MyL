		<style id="wp-custom-css">
			@media (max-width: 768px) {

  /* Eliminar borde y sombra del card */
  .archive-borders-enabled .entry-preview .post-outer,
  .archive-shadow-enabled .entry-preview .post-outer {
    border: none !important;
    box-shadow: none !important;
  }

  /* Reducir font-size del título */
  .entry-preview .entry-title {
    font-size: 17px !important;
    line-height: 1.3 !important;
    text-transform: none !important;
    letter-spacing: 0 !important;
  }

  .entry-preview .entry-title a {
    font-size: 17px !important;
    text-transform: none !important;
  }

  /* Mantener botón verde */
  .entry-preview .entry-more .button {
    background-color: #4a7c2f !important;
    border-color: #4a7c2f !important;
    color: #ffffff !important;
  }

  /* Separación limpia entre posts */
  .entry-preview {
    margin-bottom: 2rem !important;
    padding-bottom: 1.5rem !important;
    border-bottom: 1px solid #e8e8e8 !important;
  }
}

.meta-share-links .pk-share-buttons-scheme-default {
    background: #000;
    box-shadow: none;
}

.navbar-brand img {
    max-width: inherit;
    max-height: 90px !important;
    width: auto;
}
.widget-area {
	padding-top: 20px;
	padding-left: 15px;
	padding-right: 15px;
	padding-bottom: 20px;
/*	background-image: url("https://blog.humankind.cl/wp-content/uploads/stockvault-white-grunge-texture117715-scaled.jpg");
	background-attachment: fixed ;*/
	background-color: #e5e5e5;
}
.archive-wrap {
	padding-top: 20px;
	padding-left: 15px;
	padding-right: 15px;
	padding-bottom: 20px;
/*	background-image: url("https://blog.humankind.cl/wp-content/uploads/stockvault-white-grunge-texture117715-scaled.jpg");
	background-attachment: fixed; */
	background-color: #e5e5e5;
}
.entry-preview {
	padding-top: 20px;
	padding-left: 15px;
	padding-right: 15px;
	padding-bottom: 20px;
/*	background-image: url("https://blog.humankind.cl/wp-content/uploads/stockvault-white-grunge-texture117715-scaled.jpg");
	background-attachment: fixed; */
	background-color: #e5e5e5;
}
.cs-hero .hero-full article {
    color: #fff !important;
}
.footer-info{
	background: #1c1c1c !important;
	color: #fff !important;
}

.navbar,
.navbar-wrap,
.navbar-container,
.navbar-content {
  border-bottom: none !important;
  border: none !important;
  box-shadow: none !important;
}

.cs-overlay-ratio .cs-overlay-wrap img,
.post-thumbnail img {
  object-fit: contain !important;
  background: #000; /* rellena los bordes vacíos */
}
.cs-hero .hero-list {
    background: #ffffffb8;
}
.meta-category a .label  {
    color: #bdbaba !important;
}
.pk-scroll-to-top .pk-icon {
    background: #62800f !important;
}

/* Fondo negro para el bloque numerado */
.hero-section .hero-numbered-list,
.hero-widget .hero-numbered-list {
  background-color: rgba(0, 0, 0, 0.70) !important;
}

/* Texto blanco dentro del bloque */
.hero-numbered-list .hero-title a,
.hero-numbered-list .meta-category .label,
.hero-numbered-list .cs-post-data {
  color: #ffffff !important;
}

/* Por si el tema aplica color por data-scheme */
[data-scheme="default"] .hero-numbered-list {
  background-color: rgba(0, 0, 0, 0.70) !important;
  color: #ffffff !important;
}

/* Boxed para Spotlight Instagram Feed */
.sbi-feed-container,
.spotlight-instagram-feed {
  max-width: 1200px !important;
  margin-left: auto !important;
  margin-right: auto !important;
  padding: 0 20px !important;
}

.pk-alert {
    display: none !important;
}
@media (max-width: 768px) {
  .hero-numbered-list {
    display: none !important;
  }
}

@media (max-width: 768px) {

  .hero-post,
  .cs-hero,
  .hero-section {
    max-height: 550px !important;
    overflow: hidden !important;
  }

  .hero-overlay.cs-overlay-background img {
    object-fit: cover !important;
    object-position: 25% center !important;
  
}
	
}
